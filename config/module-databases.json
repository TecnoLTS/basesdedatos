{
  "schemaVersion": 1,
  "sharedService": {
    "container": "basesdedatos",
    "networkAlias": "db",
    "engine": "PostgreSQL 18.4"
  },
  "databases": [
    {
      "moduleKey": "platform-core",
      "databaseName": "paramascotasec",
      "runtimeRole": {
        "source": "env-file",
        "envFile": "../backend/entorno/.env",
        "databaseKey": "DB_DATABASE",
        "usernameKey": "DB_USERNAME",
        "passwordKey": "DB_PASSWORD",
        "optional": false
      }
    },
    {
      "moduleKey": "identity-platform",
      "databaseName": "identity_platform",
      "runtimeRole": {
        "source": "env-file",
        "envFile": "../backend/entorno/.env",
        "databaseKey": "DB_DATABASE_IDENTITY_PLATFORM",
        "usernameKey": "DB_USERNAME",
        "passwordKey": "DB_PASSWORD",
        "optional": false
      }
    },
    {
      "moduleKey": "catalog-inventory",
