      "runtimeRole": {
        "source": "env-file",
        "envFile": "../backend/entorno/.env",
        "databaseKey": "DB_DATABASE_CATALOG_INVENTORY",
        "usernameKey": "DB_USERNAME",
        "passwordKey": "DB_PASSWORD",
        "optional": false
      }
    },
    {
